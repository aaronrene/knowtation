# Copy to .env and set your keys. Do not commit .env.
# OPENAI_API_KEY=sk-your-key-here
# Hub (Phase 11): required for npm run hub (self-hosted). See docs/TWO-PATHS-HOSTED-AND-SELF-HOSTED.md#quick-start-self-hosted
# HUB_JWT_SECRET=your-long-random-secret
# KNOWTATION_VAULT_PATH=/absolute/path/to/vault (or set in config/local.yaml)
#
# Optional: before `dfx deploy hub --network ic`, `npm run canister:release-prep` can export one vault to ./backups/
# KNOWTATION_CANISTER_BACKUP_USER_ID=google:123
# KNOWTATION_CANISTER_URL=https://<canister-id>.icp0.io
# KNOWTATION_CANISTER_BACKUP_VAULT_ID=default
#
# CLI / curl / repo scripts (verify-hosted-hub-api, seed:*, `knowtation propose`) read KNOWTATION_HUB_URL,
# KNOWTATION_HUB_TOKEN, KNOWTATION_HUB_VAULT_ID — not *_LOCAL / *_HOSTED. If you use suffixed names in .env,
# after `source .env` run exports, e.g. for hosted:
#   export KNOWTATION_HUB_URL="$KNOWTATION_HUB_URL_HOSTED"
#   export KNOWTATION_HUB_TOKEN="$KNOWTATION_HUB_TOKEN_HOSTED"
#   export KNOWTATION_HUB_VAULT_ID="$KNOWTATION_HUB_VAULT_ID_HOSTED"
